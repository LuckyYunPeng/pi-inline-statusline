{
	"name": "pi-inline-statusline",
	"version": "0.16.0-beta.1",
	"description": "A single-line statusline extension for the Pi coding agent.",
	"type": "module",
	"license": "MIT",
	"private": false,
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi",
		"statusline",
		"inline",
		"single-line",
		"footer"
	],
	"files": [
		"src",
		"presets",
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./src/statusline.ts"
		]
	},
	"scripts": {
		"check": "biome check . && npm run typecheck && npm test",
		"format": "biome check --write .",
		"test": "node --import tsx --test test/statusline.test.ts",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@earendil-works/pi-coding-agent": "0.80.3",
		"@earendil-works/pi-tui": "0.80.3",
		"@types/node": "26.1.1",
		"tsx": "4.20.6",
		"typescript": "6.0.3"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/LuckyYunPeng/pi-inline-statusline.git"
	},
	"bugs": {
		"url": "https://github.com/LuckyYunPeng/pi-inline-statusline/issues"
	},
	"homepage": "https://github.com/LuckyYunPeng/pi-inline-statusline#readme",
	"publishConfig": {
		"access": "public"
	}
}
