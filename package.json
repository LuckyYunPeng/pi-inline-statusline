{
	"name": "@luckyyunpeng/pi-statusline",
	"version": "0.15.1",
	"description": "Private fork of the Pi statusline extension.",
	"type": "module",
	"license": "MIT",
	"private": true,
	"keywords": [
		"pi-package",
		"pi-extension",
		"pi",
		"statusline",
		"footer"
	],
	"files": [
		"src",
		"presets",
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./src/statusline.ts"
		]
	},
	"scripts": {
		"check": "biome check . && npm run typecheck && npm test",
		"format": "biome check --write .",
		"test": "node --import tsx --test test/statusline.test.ts",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@earendil-works/pi-coding-agent": "0.80.3",
		"@earendil-works/pi-tui": "0.80.3",
		"@types/node": "26.1.1",
		"tsx": "4.20.6",
		"typescript": "6.0.3"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/LuckyYunPeng/pi-statusline.git"
	}
}
